<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:fitsSystemWindows="true"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    tools:context=".AdminActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="24dp" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="24dp" />

    <!-- ✅ Header Title -->
    <TextView
        android:id="@+id/textHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/admin_panel_title"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="@color/md_theme_primary"
        android:gravity="center"
        android:paddingBottom="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintEnd_toEndOf="@id/guideline_end" />

    <!-- Search box -->
    <EditText
        android:id="@+id/searchNameEditText"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/shape_rounded_edittext_bg"
        android:hint="@string/hint_search_name"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical"
        android:inputType="textPersonName"
        android:textColor="@color/md_theme_onSurface"
        android:textColorHint="@color/hint_text_color"
        app:layout_constraintTop_toBottomOf="@id/dateFilterRow"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintEnd_toEndOf="@id/guideline_end" />

    <!-- 🔹 Section Spinner -->
    <LinearLayout
        android:id="@+id/sectionFilterLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/textHeader"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintEnd_toEndOf="@id/guideline_end">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_label_section"
            android:textColor="@color/md_theme_onBackground"
            android:textSize="14sp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="8dp" />

        <Spinner
            android:id="@+id/sectionSpinner"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/spinner_bg"
            android:spinnerMode="dropdown" />
    </LinearLayout>

    <!-- Date Filter Row -->
    <LinearLayout
        android:id="@+id/dateFilterRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/sectionFilterLayout"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintEnd_toEndOf="@id/guideline_end">

        <TextView
            android:id="@+id/dateFilterButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/shape_rounded_edittext_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/admin_filter_date"
            android:textColor="@color/hint_text_color" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearDateFilterButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:minHeight="48dp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="0dp"
            android:text="@string/admin_filter_clear"
            android:textColor="@color/md_theme_onSurface"
            app:cornerRadius="8dp"
            app:strokeColor="@color/md_theme_outline" />
    </LinearLayout>

    <!-- 🔹 Total Count -->
    <TextView
        android:id="@+id/totalCountText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/admin_label_total"
        android:textSize="16sp"
        android:textColor="@color/md_theme_primary"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:layout_constraintTop_toBottomOf="@id/searchNameEditText"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintEnd_toEndOf="@id/guideline_end" />

    <!-- 🔹 Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleSmall"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginTop="12dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/totalCountText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 🔹 SwipeRefresh + RecyclerView -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/totalCountText"
        app:layout_constraintBottom_toTopOf="@id/buttonLayout"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintEnd_toEndOf="@id/guideline_end">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:background="@color/md_theme_surface"
            android:padding="8dp"
            android:paddingBottom="12dp"
            android:scrollbars="vertical"
            tools:listitem="@layout/item_attendance" />
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- 🔹 Bottom Buttons: Export + Logout -->
    <LinearLayout
        android:id="@+id/buttonLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintBottom_toTopOf="@id/bannerAdView"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintEnd_toEndOf="@id/guideline_end">

        <!-- Export Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_export_csv"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/admin_button_export_csv"
            android:textColor="@color/md_theme_onSurface"
            android:paddingVertical="0dp"
            app:cornerRadius="8dp"
            app:strokeColor="@color/md_theme_outline"
            app:icon="@drawable/ic_baseline_file_download_24"
            app:iconTint="@color/md_theme_onSurface"/>


        <!-- Logout Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/logoutButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/admin_button_logout"
            android:textColor="@color/white"
            android:backgroundTint="@color/md_theme_error"
            android:paddingVertical="0dp"
            app:cornerRadius="8dp"
            app:icon="@drawable/ic_baseline_logout_24"
            app:iconTint="@color/md_theme_onError" />
    </LinearLayout>

    <com.google.android.gms.ads.AdView
        android:id="@+id/bannerAdView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:adSize="BANNER"
        app:adUnitId="@string/admob_banner_main"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
