<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/historyRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_background"
    android:fitsSystemWindows="true"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Start guideline -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_start"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_begin="24dp" />

    <!-- End guideline -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_end="24dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/historyTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/attendance_history"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/md_theme_primary"
        android:gravity="center"
        android:paddingBottom="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintEnd_toEndOf="@id/guideline_end" />

    <LinearLayout
        android:id="@+id/dateFilterRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/historyTitle"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintEnd_toEndOf="@id/guideline_end">

        <TextView
            android:id="@+id/dateFilterButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/shape_rounded_edittext_bg"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:text="@string/history_filter_date"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/hint_text_color" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearDateFilterButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:minHeight="48dp"
            android:paddingHorizontal="14dp"
            android:paddingVertical="0dp"
            android:text="@string/history_filter_clear"
            android:textColor="@color/md_theme_onSurface"
            app:cornerRadius="8dp"
            app:strokeColor="@color/md_theme_outline" />
    </LinearLayout>

    <!-- Search box -->
    <EditText
        android:id="@+id/searchNameEditText"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/shape_rounded_edittext_bg"
        android:hint="@string/hint_search_name"
        android:inputType="textPersonName"
        android:autofillHints="name"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:gravity="center_vertical"
        android:textColor="@color/md_theme_onSurface"
        android:textColorHint="@color/hint_text_color"
        app:layout_constraintTop_toBottomOf="@id/dateFilterRow"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintEnd_toEndOf="@id/guideline_end" />

    <!-- Pull-to-refresh with RecyclerView -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/searchNameEditText"
        app:layout_constraintBottom_toTopOf="@id/totalTextView"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintEnd_toEndOf="@id/guideline_end">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewHistory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:scrollbars="vertical"
            android:background="@color/md_theme_surface"
            android:padding="8dp" />

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Total Count -->
    <TextView
        android:id="@+id/totalTextView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/history_label_total"
        android:textSize="16sp"
        android:textColor="@color/md_theme_primary"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        app:layout_constraintTop_toBottomOf="@id/swipeRefreshLayout"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintEnd_toEndOf="@id/guideline_end" />

    <!-- Upload Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/syncButton"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="@string/history_button_upload"
        android:backgroundTint="@color/md_theme_primary"
        android:paddingVertical="0dp"
        app:cornerRadius="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/totalTextView"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintEnd_toEndOf="@id/guideline_end" />

    <!-- Buttons Row (Export + Clear) -->
    <LinearLayout
        android:id="@+id/buttonRow"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintTop_toBottomOf="@id/syncButton"
        app:layout_constraintBottom_toTopOf="@id/bannerAdView"
        app:layout_constraintStart_toStartOf="@id/guideline_start"
        app:layout_constraintEnd_toEndOf="@id/guideline_end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/exportCSVButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/export_csv"
            android:textColor="@color/md_theme_onSurface"
            android:paddingVertical="0dp"
            app:strokeColor="@color/md_theme_outline"
            app:cornerRadius="8dp"
            android:layout_marginEnd="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clearHistoryButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/clear_history"
            android:textColor="@color/md_theme_onSurface"
            android:paddingVertical="0dp"
            app:strokeColor="@color/md_theme_outline"
            app:cornerRadius="8dp"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <com.google.android.gms.ads.AdView
        android:id="@+id/bannerAdView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:adSize="BANNER"
        app:adUnitId="@string/admob_banner_main"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
